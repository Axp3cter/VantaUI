--!strict
--[[
	Generates src/design/icons/catalog.luau from pipeline/tools/icons/catalog.json.

	The JSON map (name -> bare asset id) is the single source of truth for icons;
	the shipped Luau table is a reproducible artifact, never hand-edited. Shipping a
	curated subset instead of the full 7,433-glyph set is a switch, not an edit:

		lune run pipeline/tools/gen-icons.luau                 -- full catalog
		lune run pipeline/tools/gen-icons.luau pipeline/tools/icons/subset.txt   -- only listed names

	A subset file is newline-separated glyph names; unknown names are reported and
	skipped so a typo can't silently shrink the set.
]]

local fs = require("@lune/fs")
local process = require("@lune/process")
local serde = require("@lune/serde")

local CATALOG = "pipeline/tools/icons/catalog.json"
local OUTPUT = "src/design/icons/catalog.luau"
local ASSET_PREFIX = "rbxassetid://"

local source: { [string]: string } = serde.decode("json", fs.readFile(CATALOG))

-- Optional subset: keep only the listed names.
local subsetPath = process.args[1]
local include: { [string]: boolean }? = nil
if subsetPath ~= nil then
	local includeSet: { [string]: boolean } = {}
	for line in string.gmatch(fs.readFile(subsetPath), "[^\r\n]+") do
		local name = string.match(line, "^%s*(.-)%s*$")
		if name ~= nil and name ~= "" then
			if source[name] == nil then
				print(`[gen-icons] warning: subset name "{name}" is not in the catalog`)
			else
				includeSet[name] = true
			end
		end
	end
	include = includeSet
end

-- Collect and sort the kept names for a stable, diff-friendly output.
local names: { string } = {}
for name in source do
	if include == nil or include[name] then
		table.insert(names, name)
	end
end
table.sort(names)

local lines: { string } = table.create(#names + 5)
table.insert(lines, "--!strict")
table.insert(lines, "--!optimize 2")
table.insert(
	lines,
	"-- @generated by pipeline/tools/gen-icons.luau from pipeline/tools/icons/catalog.json -- do not edit."
)
table.insert(lines, "")
table.insert(lines, "return table.freeze({")
for _, name in names do
	table.insert(lines, `\t["{name}"] = "{ASSET_PREFIX}{source[name]}",`)
end
table.insert(lines, "}) :: { [string]: string }")
table.insert(lines, "")

fs.writeFile(OUTPUT, table.concat(lines, "\n"))
print(`[gen-icons] wrote {OUTPUT} with {#names} glyph(s)`)
